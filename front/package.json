{
  "name": "ja.nz-frontend",
  "version": "0.0.1",
  "description": "SvelteKit frontend for my blog",
  "type": "module",
  "scripts": {
    "sk": "svelte-kit",
    "start": "run-p 'cssgen dev' 'sk dev'",
    "build": "run-s 'cssgen build' 'sk build'",
    "cssgen": "node ./css-gen.js",
    "w:debug": "yarn wrangler tail",
    "w:debug:pretty": "yarn wrangler tail --format=pretty",
    "w:pub": "yarn wrangler publish",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write --plugin-search-dir=.. .",
    "lint": "prettier --check --plugin-search-dir=.. . && eslint --ignore-path .prettierignore .",
    "package": "svelte-kit package",
    "prepare": "svelte-kit sync",
    "preview": "svelte-kit preview"
  },
  "dependencies": {
    "@fontsource/fira-mono": "^4.5.8",
    "@lukeed/uuid": "^2.0.0",
    "@thi.ng/transducers": "^8.3.2",
    "cookie": "^0.5.0",
    "mdsvex": "^0.10.5",
    "rehype-stringify": "^9.0.3",
    "remark-frontmatter": "^4.0.1",
    "remark-gfm": "^3.0.1",
    "remark-parse": "^10.0.1",
    "remark-rehype": "^10.1.0",
    "unified": "^10.1.2",
    "vfile-matter": "^3.0.1"
  },
  "devDependencies": {
    "@cloudflare/wrangler": "^1.19.12",
    "@sveltejs/adapter-cloudflare-workers": "^1.0.0-next.39",
    "@sveltejs/kit": "^1.0.0-next.326",
    "@types/cookie": "^0.5.1",
    "@typescript-eslint/eslint-plugin": "^5.22.0",
    "@typescript-eslint/parser": "^5.22.0",
    "chokidar": "^3.5.3",
    "eslint": "^8.15.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-svelte3": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.6.2",
    "prettier-plugin-svelte": "^2.7.0",
    "svelte": "^3.48.0",
    "svelte-check": "^2.7.0",
    "svelte-preprocess": "^4.10.6",
    "tailwindcss": "^3.0.24",
    "tslib": "^2.4.0",
    "typescript": "~4.6.4"
  }
}
