{
  "name": "ja.nz",
  "version": "0.0.1",
  "description": "SvelteKit frontend for my blog",
  "type": "module",
  "scripts": {
    "_cssgen": "node ./css-gen.js",
    "_eslint": "eslint -c ../.eslintrc.cjs --ignore-path .prettierignore .",
    "_prettier": "prettier --ignore-path ../.prettierignore --plugin-search-dir=.. .",
    "_sk": "svelte-kit",
    "start": "run-p '_cssgen dev' '_sk dev'",
    "build": "run-s '_cssgen build' '_sk build'",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "yarn _prettier --write",
    "lint": "yarn _prettier --check && yarn _eslint",
    "package": "svelte-kit package",
    "prepare": "svelte-kit sync",
    "preview": "svelte-kit preview"
  },
  "dependencies": {
    "@fontsource/fira-mono": "^4.5.8",
    "@lukeed/uuid": "^2.0.0",
    "@thi.ng/compose": "^2.1.6",
    "@thi.ng/paths": "^5.1.6",
    "@thi.ng/transducers": "^8.3.2",
    "cookie": "^0.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^3.11.0",
    "@fullhuman/postcss-purgecss": "^4.1.3",
    "@sveltejs/adapter-cloudflare-workers": "^1.0.0-next.40",
    "@sveltejs/kit": "^1.0.0-next.338",
    "@thi.ng/api": "^8.3.6",
    "@types/cookie": "^0.5.1",
    "@typescript-eslint/eslint-plugin": "^5.25.0",
    "@typescript-eslint/parser": "^5.25.0",
    "autoprefixer": "^10.4.7",
    "chokidar": "^3.5.3",
    "eslint": "^8.16.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-svelte3": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.14",
    "prettier": "^2.6.2",
    "prettier-plugin-svelte": "^2.7.0",
    "svelte": "^3.48.0",
    "svelte-check": "^2.7.1",
    "svelte-preprocess": "^4.10.6",
    "tailwindcss": "^3.0.24",
    "tslib": "^2.4.0",
    "tsm": "^2.2.1",
    "typescript": "~4.6.4"
  }
}
