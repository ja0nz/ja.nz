{
  "name": "ja.nz-frontend",
  "version": "0.0.1",
  "description": "SvelteKit frontend for my blog",
  "type": "module",
  "scripts": {
    "sk": "svelte-kit",
    "start": "run-p 'cssgen dev' 'sk dev'",
    "build": "run-s 'cssgen build' 'sk build'",
    "cssgen": "node ./css-gen.js",
    "w:debug": "yarn wrangler tail",
    "w:debug:pretty": "yarn wrangler tail --format=pretty",
    "w:pub": "yarn wrangler publish",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write --plugin-search-dir=. .",
    "lint": "prettier --check --plugin-search-dir=. . && eslint --ignore-path .prettierignore .",
    "package": "svelte-kit package",
    "prepare": "svelte-kit sync",
    "preview": "svelte-kit preview"
  },
  "dependencies": {
    "@fontsource/fira-mono": "^4.5.0",
    "@lukeed/uuid": "^2.0.0",
    "cookie": "^0.4.1"
  },
  "devDependencies": {
    "@cloudflare/wrangler": "^1.19.12",
    "@sveltejs/adapter-auto": "next",
    "@sveltejs/adapter-cloudflare-workers": "next",
    "@sveltejs/kit": "next",
    "@types/cookie": "^0.4.1",
    "@typescript-eslint/eslint-plugin": "^5.10.1",
    "@typescript-eslint/parser": "^5.10.1",
    "chokidar": "^3.5.3",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-svelte3": "^3.2.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.5.1",
    "prettier-plugin-svelte": "^2.5.0",
    "svelte": "^3.46.0",
    "svelte-check": "^2.2.6",
    "svelte-preprocess": "^4.10.1",
    "tailwindcss": "^3.0.24",
    "tslib": "^2.3.1",
    "typescript": "~4.6.2"
  }
}
