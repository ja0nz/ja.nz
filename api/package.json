{
  "name": "ja.nz-blog-api",
  "version": "1.0.0",
  "description": "Cloudflare worker TypeScript template",
  "main": "dist/worker.mjs",
  "type": "module",
  "scripts": {
    "build": "tsc && node esbuild.config.js",
    "pub": "yarn wrangler publish",
    "secret": "yarn wrangler secret",
    "debug": "yarn wrangler tail",
    "format": "prettier --write  '*.{json,js}' 'src/**/*.{js,ts}' 'test/**/*.{js,ts}'",
    "lint": "eslint --max-warnings=0 src && prettier --check '*.{json,js}' 'src/**/*.{js,ts}' 'test/**/*.{js,ts}'",
    "test": ""
  },
  "author": "Ja0nz <mail@ja.nz>",
  "license": "Apache-2.0",
  "eslintConfig": {
    "root": true,
    "extends": [
      "typescript",
      "prettier"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^3.9.0",
    "@cloudflare/wrangler": "^1.19.12",
    "@thi.ng/api": "^8.3.5",
    "@types/node": "^17.0.31",
    "@typescript-eslint/eslint-plugin": "^5.22.0",
    "@typescript-eslint/parser": "^5.22.0",
    "esbuild": "^0.14.38",
    "eslint": "^8.14.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-typescript": "^3.0.0",
    "prettier": "^2.6.2",
    "typescript": "^4.6.4"
  },
  "dependencies": {
    "@octokit/graphql": "^4.8.0",
    "@thi.ng/compose": "^2.1.5",
    "@thi.ng/paths": "^5.1.5",
    "gh-cms-ql": "^0.1.3",
    "itty-router": "^2.6.1"
  }
}
