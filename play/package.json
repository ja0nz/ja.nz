{
  "name": "play.ja.nz",
  "version": "0.0.1",
  "description": "A non kinda hidden but public playground",
  "type": "module",
  "scripts": {
    "_eslint": "eslint -c ../.eslintrc.cjs --ignore-path .prettierignore .",
    "_prettier": "prettier --ignore-path ../.prettierignore --plugin-search-dir=.. .",
    "build": "svelte-kit build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "yarn _prettier --write",
    "lint": "yarn _prettier --check && yarn _eslint",
    "package": "svelte-kit package",
    "prepare": "svelte-kit sync",
    "preview": "svelte-kit preview",
    "start": "svelte-kit dev"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare-workers": "^1.0.0-next.45",
    "@sveltejs/kit": "^1.0.0-next.354",
    "@typescript-eslint/eslint-plugin": "^5.29.0",
    "@typescript-eslint/parser": "^5.29.0",
    "eslint": "^8.18.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-svelte3": "^4.0.0",
    "prettier": "^2.7.1",
    "prettier-plugin-svelte": "^2.7.0",
    "svelte": "^3.48.0",
    "svelte-check": "^2.7.2",
    "svelte-highlight": "^6.1.0",
    "svelte-preprocess": "^4.10.7",
    "tslib": "^2.4.0",
    "typescript": "~4.7.4"
  }
}
